PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://username:password@cluster.mongodb.net/davinto
JWT_SECRET=replace_with_secure_secret
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

CUSTOMER_ACCESS_TOKEN_SECRET=
CUSTOMER_REFRESH_TOKEN_SECRET=
CUSTOMER_ACCESS_TOKEN_EXPIRES_IN=15m
CUSTOMER_REFRESH_TOKEN_EXPIRES_IN=30d

# Optional rate-limit overrides. Defaults use a 15-minute window.
RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
REFRESH_RATE_LIMIT_MAX=30
TRACKING_RATE_LIMIT_MAX=20
ORDER_CREATE_RATE_LIMIT_MAX=15
PAYMENT_RETRY_RATE_LIMIT_MAX=10

ADMIN_NAME=Admin
ADMIN_EMAIL=admin@davinto.com
ADMIN_PASSWORD=ChangeThisPassword123

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=davinto

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_SECURE=true
# Optional local-development workaround for intercepted/self-signed SMTP TLS chains.
# Keep true in production. Set false only in local development if smtp:test/order emails fail TLS verification.
SMTP_TLS_REJECT_UNAUTHORIZED=true
EMAIL_FROM="Davinto" <your-email@gmail.com>
ADMIN_ORDER_EMAIL=owner-email@gmail.com

PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=
PAYMOB_BASE_URL=https://accept.paymob.com
PAYMOB_CURRENCY=EGP
